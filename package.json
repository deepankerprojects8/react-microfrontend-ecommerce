{
  "name": "@react-microfrontend-workspace/source",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev -w apps/customer-app",
    "dev:customer": "npm run dev -w apps/customer-app",
    "dev:admin": "npm run dev -w apps/admin-dashboard",
    "dev:catalog": "npm run dev -w apps/product-catalog",

    "build": "nx run-many --target=build --all",
    "build:customer": "npm run build -w apps/customer-app",
    "build:admin": "npm run build -w apps/admin-dashboard",
    "build:catalog": "npm run build -w apps/product-catalog",
    "build:affected": "nx affected --target=build",

    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:customer": "eslint apps/customer-app/src --ext .ts,.tsx",
    "lint:admin": "eslint apps/admin-dashboard/src --ext .ts,.tsx",
    "lint:catalog": "eslint apps/product-catalog/src --ext .ts,.tsx",
    "lint:all": "nx run-many --target=lint --all",
    "lint:affected": "nx affected --target=lint",

    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:customer": "jest --testPathPattern=apps/customer-app --no-coverage",
    "test:admin": "jest --testPathPattern=apps/admin-dashboard --no-coverage",
    "test:catalog": "jest --testPathPattern=apps/product-catalog --no-coverage",
    "test:affected": "nx affected --target=test",

    "typecheck": "tsc --noEmit",
    "typecheck:affected": "nx affected --target=typecheck",

    "format": "prettier --write .",
    "graph": "nx graph"
  },
  "private": true,
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "^22.6.1",
    "@nx/eslint-plugin": "^22.6.1",
    "@nx/js": "^22.6.1",
    "@nx/react": "^22.6.1",
    "@nx/vite": "^22.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "10.4.13",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "nx": "^22.6.1",
    "postcss": "8.4.38",
    "prettier": "~3.6.2",
    "tailwindcss": "3.4.3",
    "ts-jest": "^29.4.6",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.0.0"
  },
  "workspaces": [
    "libs/*",
    "apps/*"
  ]
}

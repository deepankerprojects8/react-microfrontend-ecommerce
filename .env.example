# Copy this file to .env and adjust values for your machine.
#
# REQUIRED on Windows when the workspace path contains spaces
# (e.g. "C:\Users\...\Personal Projects\...").
# Nx's default plugin-worker model uses named-pipe IPC sockets; paths with
# spaces break the socket URI, causing the js/package-json/project-json
# built-in plugins to crash with a 5-second timeout error.
#
# Both variables below are already set in nx.json / defaulted to false,
# but duplicating them here ensures the Nx Console VS Code extension and
# other external tooling pick them up (they read .env, not nx.json flags).

NX_ISOLATE_PLUGINS=false
NX_DAEMON=false
